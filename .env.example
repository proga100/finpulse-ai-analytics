# --- Backend -----------------------------------------------------------------
# Read-only application role over the synthetic `fin` schema (see database/read_only_user.sql).
DATABASE_URL=postgresql://finpulse_ai_app:change_this_app_password@db:5432/finpulse

# Shared bearer token the Next.js proxy uses to call the backend (kept server-side).
ANALYTICS_API_TOKEN=change_this_analytics_api_token

# Google Gemini powers query normalization, embeddings, summaries and the
# text-to-SQL fallback. Required. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Agent / template matching
SQL_AGENT_PROVIDER=template
TEMPLATE_VECTOR_STORE=chroma
CHROMA_PATH=/app/chromadb
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768
QUERY_NORMALIZER_PROVIDER=gemini
QUERY_NORMALIZER_MODEL=gemini-2.5-flash-lite
TEMPLATE_MATCH_THRESHOLD=0.75

# CORS (the browser talks to the Next.js frontend, which proxies to the backend).
CORS_ORIGINS=["http://localhost:3000"]

# --- Public demo gate --------------------------------------------------------
# Per-visitor question quota (session id + IP backstop). After this many
# answered questions a "this is a demo" popup is shown.
DEMO_LIMIT_ENABLED=true
DEMO_CALL_LIMIT=5
DEMO_WINDOW_SECONDS=86400

# --- Frontend ----------------------------------------------------------------
BACKEND_API_BASE_URL=http://backend:8000
